#!/bin/sh
# Click action for iTerm sessions.  Arg:  cc-focus <claude_session_id>
#
# Resolves the registered iTerm tab id (and name, for fallback) from the
# cc-notify state files, then hands them to AppleScript as arguments. No
# caller-supplied or user-controlled text is ever placed in a shell-evaluated
# context, so a hostile session name / directory name cannot inject commands.
#
# Behavior: select the tab by its stable iTerm session id (title-proof); else
# best-effort by name; and always at least activate iTerm so a click is never
# wasted.

sid="$1"
home="${CC_NOTIFY_HOME:-$HOME/.config/cc-notify}"

itermid=""
[ -n "$sid" ] && [ -f "$home/ids/$sid" ] && itermid=$(cat "$home/ids/$sid" 2>/dev/null)
name=""
[ -n "$sid" ] && [ -f "$home/names/$sid" ] && name=$(cat "$home/names/$sid" 2>/dev/null)

/usr/bin/osascript - "$itermid" "$name" <<'OSA' 2>/dev/null
on run argv
  set targetId to item 1 of argv
  set targetName to item 2 of argv
  tell application "iTerm2"
    activate
    if targetId is not "" then
      repeat with w in windows
        repeat with t in tabs of w
          repeat with s in sessions of t
            if (id of s) is targetId then
              select t
              return
            end if
          end repeat
        end repeat
      end repeat
    end if
    if targetName is not "" then
      repeat with w in windows
        repeat with t in tabs of w
          repeat with s in sessions of t
            if (name of s) contains targetName then
              select t
              return
            end if
          end repeat
        end repeat
      end repeat
    end if
  end tell
end run
OSA
