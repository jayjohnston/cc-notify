#!/bin/sh
# Claude Code "needs you" hook entrypoint (Notification event).
# Announces the session name and posts a clickable banner.

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
. "$SCRIPT_DIR/lib.sh"

cc_read_payload
# idle_prompt re-fires every ~7min for any tab still awaiting input, whether
# or not it's the one you currently care about; permission_prompt and other
# notification types genuinely need you and still alert.
[ "$(printf '%s' "$payload" | jq -r '.notification_type // empty')" = "idle_prompt" ] && exit 0
cc_should_skip && exit 0

cc_notify_banner "needs you"
cc_say "$NEEDS_VOICE" "$NEEDS_PHRASE"
